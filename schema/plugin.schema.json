{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://penmods.dev/schema/plugin.schema.json",
  "title": "PenMods Plugin Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "name",
    "author",
    "category",
    "summary",
    "repo_url",
    "download_url",
    "version",
    "tags"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "core",
        "plugin"
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "category": {
      "type": "string",
      "enum": [
        "core",
        "appearance",
        "developer-tools",
        "editor",
        "integration",
        "productivity",
        "system",
        "utility",
        "other"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "description": {
      "type": "string",
      "maxLength": 4000
    },
    "icon": {
      "type": "string",
      "format": "uri"
    },
    "repo_url": {
      "type": "string",
      "format": "uri"
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "download_url": {
      "type": "string",
      "format": "uri"
    },
    "releases_url": {
      "type": "string",
      "format": "uri"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9A-Za-z.+_-]+$"
    },
    "license": {
      "type": "string",
      "maxLength": 80
    },
    "source_available": {
      "type": "boolean"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "public",
        "restricted"
      ]
    },
    "distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "url"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "direct",
            "github-release",
            "telegram",
            "website",
            "other"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "notes": {
          "type": "string",
          "maxLength": 240
        }
      }
    },
    "update": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "type": "string",
          "enum": [
            "direct",
            "staged",
            "copy-restart",
            "manual"
          ]
        },
        "target_path": {
          "type": "string",
          "maxLength": 240
        },
        "requires_restart": {
          "type": "boolean"
        },
        "notes": {
          "type": "string",
          "maxLength": 240
        }
      }
    },
    "verified": {
      "type": "boolean"
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
      }
    },
    "screenshots": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "provides": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^capability:[a-z0-9]+(?:[.-][a-z0-9]+)*$"
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {
          "$ref": "#/$defs/dependencyList"
        },
        "optional": {
          "$ref": "#/$defs/dependencyList"
        },
        "peer": {
          "$ref": "#/$defs/dependencyList"
        },
        "incompatible": {
          "$ref": "#/$defs/dependencyList"
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "penmods": {
          "type": "string",
          "maxLength": 40
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "requires": {
              "$ref": "#/$defs/capabilityList"
            },
            "conflicts": {
              "$ref": "#/$defs/capabilityList"
            },
            "optional": {
              "$ref": "#/$defs/capabilityList"
            }
          }
        },
        "capability_history": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/capabilityHistory"
          }
        }
      }
    }
  },
  "$defs": {
    "capabilityList": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^capability:[a-z0-9]+(?:[.-][a-z0-9]+)*$"
      }
    },
    "capabilityHistory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability",
        "since_version"
      ],
      "properties": {
        "capability": {
          "type": "string",
          "pattern": "^capability:[a-z0-9]+(?:[.-][a-z0-9]+)*$"
        },
        "since_version": {
          "type": "string",
          "maxLength": 40
        },
        "since_ci_version": {
          "type": "string",
          "maxLength": 80
        },
        "notes": {
          "type": "string",
          "maxLength": 240
        }
      }
    },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
        },
        "version": {
          "type": "string",
          "maxLength": 40
        },
        "capabilities": {
          "$ref": "#/$defs/capabilityList"
        },
        "reason": {
          "type": "string",
          "maxLength": 240
        }
      }
    },
    "dependencyList": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/dependency"
      }
    }
  }
}

{
  "name": "penmods-plugin-index",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "validate": "node ./scripts/validate-registry.mjs",
    "build:schema": "node ./scripts/build-schema.mjs",
    "check:schema": "node ./scripts/build-schema.mjs --check",
    "build:data": "node ./scripts/build-registry.mjs",
    "build:site": "node ./scripts/build-site.mjs",
    "build": "npm run validate && npm run build:data && npm run build:site",
    "visual": "node ./scripts/visual-check.mjs"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "playwright": "^1.61.1"
  }
}
